---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getServices, getWorks } from "../lib/strapi.js";
const services = await getServices();
const works = await getWorks();
---
<Layout title="Roofaro - Webflow HTML Website Template" description="Roofaro is a premium Webflow template built for roofing companies to attract more clients, showcase projects, and grow their business.">
  <Header current="home" />
<main class="main-wrapper">
      <section class="section_hero">
        <div class="w-layout-blockcontainer container-main w-container">
          <div class="hero-wrapper">
            <div class="hero-content-block">
              <div class="hero-text-block">
                <div to-top-0s="" class="hero-subtitle-block">
                  <div class="hero-subtitle-dot"></div>
                  <div class="hero-subtitle-text">PEAKSHIELD ROOFING</div>
                </div>
                <div class="hero-title-block">
                  <h1 hero-title="" class="heading-style-1 title-animation">Trusty Roofing Help for Your Home</h1>
                </div>
                <div to-top-2s="" class="hero-summary-block">
                  <p class="text-size-large text-color-white-800">Expert residential &amp; commercial roofing services backed by quality materials, certified professionals, and long-term warranties.</p>
                </div>
                <div to-top-4s="" class="hero-button-block">
                  <a href="/contact" button-hover="" class="primary-button w-inline-block">
                    <div class="button-content-block">
                      <div class="button-text-block">
                        <div class="button-text">Free Inspection</div>
                      </div>
                      <div class="button-icon-block">
                        <div class="button-icon w-embed"><svg width="15" height="16" viewBox="0 0 15 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M0 7.53027H14M7 14.5303L14 7.53027L7 0.530273" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
                          </svg>
                        </div>
                      </div>
                    </div>
                  </a>
                </div>
              </div>
            </div>
            <div to-top-6s="" class="hero-slider-block">
              <div class="hero-slider-content-block">
                <div class="hero-slide-card-block">
                  <div class="hero-slide-image-block"><img src="/images/Hero-Slide-Image.webp" loading="lazy" alt="Snow-covered roof edge with blooming pink flowers hanging amid falling snowflakes." class="hero-slide-image is-1"><img src="/images/Hero-Slider-Image-1.webp" loading="lazy" alt="Minimalist white building with curved and straight sections under a clear blue sky." class="hero-slide-image is-2"><img src="/images/Hero-Slider-Image.webp" loading="lazy" alt="Blue triangular house top with two rectangular windows on a white background." class="hero-slide-image is-3"></div>
                  <div class="hero-slide-content-block">
                    <div class="hero-slide-text-block">
                      <h2 class="heading-style-6 text-color-white">Storm Recovery</h2>
                      <p class="text-size-small text-color-white-800">Emergency roof restoration successfully completed within forty-eight hours.</p>
                    </div>
                    <a href="/about" class="hero-slide-button-block w-inline-block">
                      <div class="hero-slide-button">Read More</div>
                      <div class="hero-slide-button-icon-block">
                        <div class="hero-slide-button-icon w-embed"><svg width="12" height="13" viewBox="0 0 15 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M0 7.53027H14M7 14.5303L14 7.53027L7 0.530273" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
                          </svg>
                        </div>
                      </div>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="section_about">
        <div class="section-gap">
          <div class="w-layout-blockcontainer container-main w-container">
            <div class="about-wrapper">
              <div reveal-0s="" class="about-heading-block">
                <div class="section-subtitle-block">
                  <div class="subtitle-dot"></div>
                  <p class="subtitle-text">ABOUT PEAKSHIELD</p>
                </div>
                <div class="about-title-block">
                  <h2 class="about-title-text">With more than 20 years in the roofing game, we&#x27;ve earned a solid reputation for being reliable and delivering top-notch craftsmanship. Our certified pros are all about keeping your home safe with the best roofing solutions out there.</h2>
                </div>
              </div>
              <div reveal-2s="" class="about-info-block">
                <div class="about-raitng-info-block">
                  <div class="about-raitng-avatar-block"><img src="/images/avatar-03.png" loading="lazy" alt="Smiling animated woman with short brown hair wearing an orange strapless top." class="about-raitng-avatar is-1"><img src="/images/avatar-02.png" loading="lazy" alt="3D female avatar with dark hair tied back, wearing a grey top, orange background." class="about-raitng-avatar"><img src="/images/avatar-01.png" loading="lazy" alt="Cartoon avatar of a young man with brown hair and glasses on a purple background." class="about-raitng-avatar"></div>
                  <div class="about-raitng-text-block">
                    <div class="about-raitng-star-block"><img src="/images/Star-Icon-2.svg" loading="lazy" alt="Star Icon " class="about-raitng-star"><img src="/images/Star-Icon-2.svg" loading="lazy" alt="Star Icon " class="about-raitng-star"><img src="/images/Star-Icon-2.svg" loading="lazy" alt="Star Icon " class="about-raitng-star"><img src="/images/Star-Icon-2.svg" loading="lazy" alt="Star Icon " class="about-raitng-star"><img src="/images/Star-Icon-2.svg" loading="lazy" alt="Star Icon " class="about-raitng-star"></div>
                    <p class="text-size-small heading-text-color">Rated 4.9/5 reviews</p>
                  </div>
                </div>
                <div class="about-stat-info-block">
                  <div class="about-single-stat-block">
                    <h3 class="about-stat-number _wf-counter">10+</h3>
                    <p class="text-size-regular">Years of Experience</p>
                  </div>
                  <div class="about-single-stat-block">
                    <h3 class="about-stat-number _wf-counter">250+</h3>
                    <p class="text-size-regular">Roofs Installed</p>
                  </div>
                  <div class="about-single-stat-block">
                    <h3 class="about-stat-number _wf-counter">4.9/5</h3>
                    <p class="text-size-regular">Client Rating</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="section_services">
        <div class="section-gap bottom-gap">
          <div class="w-layout-blockcontainer container-main w-container">
            <div class="services-wrapper">
              <div class="section-heading-block bottom-space-btwn">
                <div class="section-heading-text-block">
                  <div reveal-0s="" class="section-subtitle-block bottom-space">
                    <div class="subtitle-dot"></div>
                    <p class="subtitle-text">OUR CORE SERVICES</p>
                  </div>
                  <div class="section-title-block max-width-40">
                    <h2 section-title="" class="heading-style-2 title-animation">Complete Roofing Solutions Under One Structure</h2>
                  </div>
                </div>
                <div reveal-2s="" class="section-summary-block max-width-20">
                  <p class="text-size-large">Roofaro provides reliable roofing systems for homes and commercial properties across all industries.</p>
                </div>
              </div>
              <div reveal-4s="" class="services-content-block">
                <div data-delay="4000" class="services-slider-block w-slider" data-autoplay="false" data-hide-arrows="false" data-disable-swipe="false" data-autoplay-limit="0" data-nav-spacing="3" data-infinite="true">
                  <div class="services-slider-mask w-slider-mask">
                    {services.map((s) => (
                    <div class="services-slide-block w-slide">
                      <div class="services-collection-block">
                        <div class="services-collection-list">
                          <div class="services-collection-item">
                            <div class="services-item-card-block">
                              <div class="services-item-heading-block">
                                <div class="services-item-number-block">
                                  <p class="text-size-regular text-weight-medium text-color-black"></p>
                                  <p class="text-size-regular text-weight-medium">/{s.serviceNumber}</p>
                                </div>
                                <a aria-label={s.serviceName} href={`/services/${s.slug}`} class="services-item-title-block w-inline-block">
                                  <h3 class="service-item-title">{s.serviceName}</h3>
                                </a>
                              </div>
                              <div class="services-item-image-block"><img src={s.serviceThumbnail} loading="lazy" alt={s.serviceName} class="services-item-image">
                                <div class="services-item-stat-block">
                                  <div class="services-stat-number _wf-counter">{s.statNumber}</div>
                                  <p>{s.statText}</p>
                                </div>
                              </div>
                              <div class="services-item-content-block">
                                <div class="services-content-top-block">
                                  <p class="text-size-large text-color-black">{s.serviceSummary}</p>
                                </div>
                                <div class="services-content-bottom-block">
                                  <div class="services-item-keypoint-block">
                                    <div class="services-item-keypoint w-richtext" set:html={s.serviceKeyPoints}></div>
                                  </div>
                                  <div class="services-item-button-block">
                                    <a href={`/services/${s.slug}`} button-hover class="primary-button w-inline-block">
                                      <div class="button-content-block">
                                        <div class="button-text-block"><div class="button-text">View Service</div></div>
                                        <div class="button-icon-block"><div class="button-icon w-embed"><svg width="15" height="16" viewBox="0 0 15 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 7.53027H14M7 14.5303L14 7.53027L7 0.530273" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path></svg></div></div>
                                      </div>
                                    </a>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                    ))}
                  </div>
                  <div class="services-arrow-block left w-slider-arrow-left">
                    <div class="services-arrow-icon left w-embed"><svg width="15" height="16" viewBox="0 0 15 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0 7.53027H14M7 14.5303L14 7.53027L7 0.530273" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
                      </svg>
                    </div>
                  </div>
                  <div class="services-arrow-block w-slider-arrow-right">
                    <div class="services-arrow-icon w-embed"><svg width="15" height="16" viewBox="0 0 15 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0 7.53027H14M7 14.5303L14 7.53027L7 0.530273" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
                      </svg>
                    </div>
                  </div>
                  <div class="display-none w-slider-nav w-round w-num"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section to-top-0="" class="section_partners">
        <div class="section-gap">
          <div class="w-layout-blockcontainer container-main w-container">
            <div class="partners-wrapper">
              <div class="partners-heading-block">
                <div class="partners-heading-left-block">
                  <div class="partners-heading-title-block">
                    <h2 section-title="" class="heading-style-3">Built With Industry-<br>Leading Materials, Trusted Brands, and Certified Roofing Partners</h2>
                  </div>
                  <div reveal-2s="" class="partners-heading-button-block">
                    <a href="/contact" button-hover="" class="primary-button w-inline-block">
                      <div class="button-content-block">
                        <div class="button-text-block">
                          <div class="button-text">Free Inspection</div>
                        </div>
                        <div class="button-icon-block">
                          <div class="button-icon w-embed"><svg width="15" height="16" viewBox="0 0 15 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M0 7.53027H14M7 14.5303L14 7.53027L7 0.530273" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
                            </svg>
                          </div>
                        </div>
                      </div>
                    </a>
                  </div>
                </div>
                <div reveal-4s="" class="partners-heading-right-block">
                  <div class="partners-heading-icon-block">
                    <div class="partners-heading-icon w-embed"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="11" stroke="#F47E3E" stroke-width="2"></circle>
                        <rect x="11" y="6" width="2" height="7" rx="1" fill="#F47E3E"></rect>
                        <rect x="12" y="11" width="6" height="2" rx="1" fill="#F47E3E"></rect>
                      </svg>
                    </div>
                  </div>
                  <div class="partners-heading-content-block">
                    <div class="partners-heading-text-block">
                      <h3 class="text-size-xlarge">Nearest Response Time</h3>
                    </div>
                    <div class="partners-heading-number-block">
                      <h3 class="partners-heading-number _wf-counter">12<span class="partners-heading-number-text">m</span></h3>
                    </div>
                  </div>
                </div>
              </div>
              <div class="partners-content-block">
                <div class="partners-logo-block">
                  <div reveal-2s="" class="logo-block"><img src="/images/Company-logo-2.svg" loading="lazy" alt="logo" class="logo"></div>
                  <div reveal-2s="" class="logo-block"><img src="/images/Company-logo-4.svg" loading="lazy" alt="logo" class="logo"></div>
                  <div reveal-2s="" class="logo-block"><img src="/images/Company-logo-5.svg" loading="lazy" alt="logo" class="logo"></div>
                  <div reveal-2s="" class="logo-block"><img src="/images/Company-logo-3.svg" loading="lazy" alt="logo" class="logo"></div>
                  <div reveal-2s="" class="logo-block"><img src="/images/Company-logo-9.svg" loading="lazy" alt="logo" class="logo"></div>
                  <div reveal-2s="" class="logo-block"><img src="/images/Company-logo-1.svg" loading="lazy" alt="logo" class="logo"></div>
                  <div reveal-2s="" class="logo-block"><img src="/images/Company-logo.svg" loading="lazy" alt="logo" class="logo"></div>
                  <div reveal-2s="" class="logo-block"><img src="/images/Company-logo-10.svg" loading="lazy" alt="logo" class="logo"></div>
                  <div reveal-2s="" class="logo-block"><img src="/images/Company-logo-8.svg" loading="lazy" alt="logo" class="logo"></div>
                  <div reveal-2s="" class="logo-block"><img src="/images/Company-logo-7.svg" loading="lazy" alt="logo" class="logo"></div>
                  <div reveal-2s="" class="logo-block"><img src="/images/Company-logo-6.svg" loading="lazy" alt="logo" class="logo"></div>
                  <div reveal-2s="" class="logo-block"><img src="/images/Company-logo-11.svg" loading="lazy" alt="logo" class="logo"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      <section class="section_expertise">
        <div class="section-gap">
          <div class="w-layout-blockcontainer container-main w-container">
            <div class="expertise-wrapper">
              <div class="section-heading-block bottom-space-btwn">
                <div class="section-heading-text-block">
                  <div reveal-0s="" class="section-subtitle-block bottom-space">
                    <div class="subtitle-dot"></div>
                    <p class="subtitle-text text-color-white">OUR EXPERTISE</p>
                  </div>
                  <div class="section-title-block max-width-40">
                    <h2 section-title="" class="heading-style-2 text-color-white">Metal Roofing Experts. Structural Protection Masters.</h2>
                  </div>
                </div>
                <div reveal-2s="" class="section-summary-block max-width-24">
                  <p class="text-size-large text-color-gray-400">Expert residential &amp; commercial roofing services backed by quality materials, certified professionals, and long-term warranties.</p>
                </div>
              </div>
              <div class="expertise-content-block">
                <div reveal-2s="" class="expertise-item-block is-1">
                  <div class="expertise-item-content-block">
                    <div class="expertise-item-title-block">
                      <p class="text-size-xlarge text-color-gray-400">01.</p>
                      <h3 class="heading-style-5 text-color-white">Corrugated and Ribbed</h3>
                    </div>
                    <div class="expertise-item-text-block">
                      <div class="expertise-item-summary-block">
                        <p class="text-size-regular text-color-gray-400">Our metal panel systems, with their corrugated and ribbed designs, are super strong yet lightweight.</p>
                      </div>
                      <div class="expertise-item-icon-block is-1">
                        <div class="expertise-item-icon w-embed"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <g clipPath="url(#clip0_190_2205)">
                              <path d="M12 5V19V5Z" fill="#0A0A0A"></path>
                              <path d="M12 5V19" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                              <path d="M5 12H19H5Z" fill="#0A0A0A"></path>
                              <path d="M5 12H19" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </g>
                            <defs>
                              <clipPath id="clip0_190_2205">
                                <rect width="24" height="24" fill="white"></rect>
                              </clipPath>
                            </defs>
                          </svg>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="expertise-item-image-block is-1">
                    <div class="expertise-image-inner-block"><img src="/images/Expertise-Image-1.webp" loading="lazy" sizes="100vw" srcset="images/Expertise-Image-1-p-500.webp 500w, images/Expertise-Image-1.webp 770w" alt="Close-up of a metal building wall with vertical ridges under a blue sky." class="expertise-item-image">
                      <div class="expertise-item-button-block">
                        <a href="/services" button-hover="" class="border-button w-inline-block">
                          <div class="button-content-block">
                            <div class="button-text-block">
                              <div class="button-text">View  Details</div>
                            </div>
                            <div class="button-icon-block">
                              <div class="button-icon w-embed"><svg width="15" height="16" viewBox="0 0 15 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                  <path d="M0 7.53027H14M7 14.5303L14 7.53027L7 0.530273" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
                                </svg>
                              </div>
                            </div>
                          </div>
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
                <div reveal-2s="" class="expertise-item-block is-2">
                  <div class="expertise-item-content-block">
                    <div class="expertise-item-title-block">
                      <p class="text-size-xlarge text-color-gray-400">02.</p>
                      <h3 class="heading-style-5 text-color-white">Blue Scope Certified</h3>
                    </div>
                    <div class="expertise-item-text-block">
                      <div class="expertise-item-summary-block">
                        <p class="text-size-regular text-color-gray-400">Expert roofing with trusted standards, quality materials, and proven installation.</p>
                      </div>
                      <div class="expertise-item-icon-block is-2">
                        <div class="expertise-item-icon w-embed"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <g clipPath="url(#clip0_190_2205)">
                              <path d="M12 5V19V5Z" fill="#0A0A0A"></path>
                              <path d="M12 5V19" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                              <path d="M5 12H19H5Z" fill="#0A0A0A"></path>
                              <path d="M5 12H19" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </g>
                            <defs>
                              <clipPath id="clip0_190_2205">
                                <rect width="24" height="24" fill="white"></rect>
                              </clipPath>
                            </defs>
                          </svg>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="expertise-item-image-block is-2">
                    <div class="expertise-image-inner-block"><img src="/images/Expertise-Image-2.webp" loading="lazy" sizes="100vw" srcset="images/Expertise-Image-2-p-500.webp 500w, images/Expertise-Image-2.webp 770w" alt="Top portion of a weathered red wooden barn under a partly cloudy sky." class="expertise-item-image">
                      <div class="expertise-item-button-block">
                        <a href="/services" button-hover="" class="border-button w-inline-block">
                          <div class="button-content-block">
                            <div class="button-text-block">
                              <div class="button-text">View  Details</div>
                            </div>
                            <div class="button-icon-block">
                              <div class="button-icon w-embed"><svg width="15" height="16" viewBox="0 0 15 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                  <path d="M0 7.53027H14M7 14.5303L14 7.53027L7 0.530273" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
                                </svg>
                              </div>
                            </div>
                          </div>
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
                <div reveal-2s="" class="expertise-item-block is-3">
                  <div class="expertise-item-content-block">
                    <div class="expertise-item-title-block">
                      <p class="text-size-xlarge text-color-gray-400">03.</p>
                      <h3 class="heading-style-5 text-color-white">Metal Roof design</h3>
                    </div>
                    <div class="expertise-item-text-block">
                      <div class="expertise-item-summary-block">
                        <p class="text-size-regular text-color-gray-400">Durable, custom metal roofing solutions that combine beauty and long-lasting performance.</p>
                      </div>
                      <div class="expertise-item-icon-block is-3">
                        <div class="expertise-item-icon w-embed"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <g clipPath="url(#clip0_190_2205)">
                              <path d="M12 5V19V5Z" fill="#0A0A0A"></path>
                              <path d="M12 5V19" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                              <path d="M5 12H19H5Z" fill="#0A0A0A"></path>
                              <path d="M5 12H19" stroke="#0A0A0A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </g>
                            <defs>
                              <clipPath id="clip0_190_2205">
                                <rect width="24" height="24" fill="white"></rect>
                              </clipPath>
                            </defs>
                          </svg>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="expertise-item-image-block is-3">
                    <div class="expertise-image-inner-block"><img src="/images/Expertise-Image-3.webp" loading="lazy" sizes="100vw" srcset="images/Expertise-Image-3-p-500.webp 500w, images/Expertise-Image-3.webp 770w" alt="Close-up of a white chimney on a metal sloped roof under a clear blue sky." class="expertise-item-image">
                      <div class="expertise-item-button-block">
                        <a href="/services" button-hover="" class="border-button w-inline-block">
                          <div class="button-content-block">
                            <div class="button-text-block">
                              <div class="button-text">View  Details</div>
                            </div>
                            <div class="button-icon-block">
                              <div class="button-icon w-embed"><svg width="15" height="16" viewBox="0 0 15 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                  <path d="M0 7.53027H14M7 14.5303L14 7.53027L7 0.530273" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"></path>
                                </svg>
                              </div>
                            </div>
                          </div>
                        </a>
                      </div>
                    </div>
